{
  "name": "ope-assessor",
  "version": "1.0.0",
  "private": true,
  "description": "OPE Assessor assessment app with optional shared sync server",
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "dotenv": "^16.6.1",
    "puppeteer-core": "^24.43.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  },
  "scripts": {
    "migrate:supabase": "node scripts/migrate-file-state-to-supabase.js",
    "start": "node server.js",
    "serve": "node server.js",
    "build": "node scripts/build-cf-pages.js",
    "cf:dev": "wrangler pages dev .",
    "cf:deploy": "npm run build && wrangler pages deploy"
  }
}
