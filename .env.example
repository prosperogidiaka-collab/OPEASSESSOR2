HOST=0.0.0.0
PORT=8000

# Recommended for deployment so shared data survives restarts.
DATA_DIR=./data

# Optional explicit file path. Overrides DATA_DIR when set.
# DATA_FILE=./data/ope-shared-state.json

# Optional public URL for health output and deployment clarity.
PUBLIC_BASE_URL=

# Optional comma-separated frontend origins when frontend and backend are on different domains.
# Example: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=
