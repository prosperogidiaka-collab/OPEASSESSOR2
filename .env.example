HOST=0.0.0.0
PORT=8000

# Storage backend: file, supabase, or auto
# For Vercel/serverless shared sync, use `supabase`.
STORAGE_BACKEND=file

# Recommended for deployment so shared data survives restarts.
DATA_DIR=./data

# Optional explicit file path. Overrides DATA_DIR when set.
# DATA_FILE=./data/ope-shared-state.json

# Supabase backend settings (used when STORAGE_BACKEND=supabase, or STORAGE_BACKEND=auto with both values present)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE_PREFIX=ope_

# Optional public URL for health output and deployment clarity.
PUBLIC_BASE_URL=

# Optional comma-separated frontend origins when frontend and backend are on different domains.
# Example: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# --- Authentication ---------------------------------------------------------
# The super-admin credentials live ONLY on the server. Rotate them by changing
# these values and restarting the process. The defaults preserve backward
# compatibility with installations created before the auth hardening rollout —
# CHANGE THEM in any real deployment.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Session lifetime for tokens issued by /api/auth/* endpoints (milliseconds).
# Defaults to 24 hours.
# SESSION_TTL_MS=86400000

# PBKDF2 iterations used when hashing teacher passwords. Higher = slower but
# more brute-force resistant. Default 100000.
# PBKDF2_ITERATIONS=100000

# --- PDF export -------------------------------------------------------------
# Optional explicit Chromium-compatible browser path for /api/export/pdf.
# When unset, the server auto-detects Edge/Chrome/Chromium on the host.
# PDF_BROWSER_PATH=
